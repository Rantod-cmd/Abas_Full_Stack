generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}




datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Shop {
  id        String  @id @default(cuid())
  name      String
  products  String
  theme     String
  concept   String
  location  String
  size_store String
  tools     String
  capital   String
  staff     String
  hours     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
